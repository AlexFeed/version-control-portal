# Настройки сервера
PORT=3000

# Секреты для JWT (Авторизация)
# Здесь должен быть сложный случайный набор символов
JWT_SECRET="your_super_secret_jwt_key_here"
JWT_EXPIRATION_TIME="24h"

# База данных
POSTGRES_USER=postgres
POSTGRES_PASSWORD=root
POSTGRES_DB=version_control_db

# Подключение к базе данных PostgreSQL
# Формат: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:root@localhost:5432/version_control_db?schema=public"